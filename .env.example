# PharmaGPT — environment variable reference.
# Copy to .env for local dev and fill in real values. Never commit .env
# (already in .gitignore). See docs/DEPLOYMENT.md for the Render production
# equivalent of this file (render.yaml's envVars block).

# ── Required — app will not start / auth will fail without these ─────────────

# Google Gemini API key. All AI features (chat, document generation, AI
# review, QMS assistants) fail without it.
GEMINI_API_KEY=

# Supabase project — read on every authenticated request
# (pharmagpt/auth/context.py -> pharmagpt/services/supabase_client.py).
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Signs the Flask session cookie. Has an insecure hardcoded dev fallback
# ("pharmagpt-dev-secret-key") — set a real random value in any shared or
# production environment. Render's render.yaml auto-generates this.
FLASK_SECRET_KEY=change-in-production

# ── Local dev only ─────────────────────────────────────────────────────────

# Defaults to "false" (fail-safe) if unset. Set explicitly to "true" for
# local dev to get the Werkzeug debugger + auto-reload. Must stay "false" (or
# unset) in production — "true" enables the interactive debugger (arbitrary
# code execution) and disables the secure session cookie flag.
FLASK_DEBUG=true

# Only used by the `python pharmagpt/app.py` / `flask run` dev entrypoint —
# gunicorn (Procfile/render.yaml) binds via --bind 0.0.0.0:$PORT instead.
FLASK_PORT=5000

# ── Storage paths — override in production to point at a persistent disk ────
# All three default to paths inside the repo checkout, which is fine for
# local dev but is wiped on every redeploy on an ephemeral filesystem (e.g.
# Render without these set to the mounted disk). See render.yaml.

# DB_PATH=/var/data/pharmagpt.db
# UPLOAD_FOLDER=/var/data/uploads
# GENERATED_DOCS_PATH=/var/data/generated_documents

# ── Phase 3 Postgres migration flags — leave unset / "sqlite" ────────────────
# Each defaults to "sqlite" (SQLite is the sole source of truth). "dual"
# additionally best-effort mirrors writes to Postgres. Do NOT set any of
# these to "dual" outside a real Staging soak — cutover is gated on an
# extended soak + 2-company RLS isolation check per domain, not yet done.
# See docs/PHASE3_EXECUTION_PLAN.md §3.6 and docs/PHASE3_FLAGS.md.
# DATABASE_BACKEND=sqlite
# PROJECTS_BACKEND=sqlite
# KB_BACKEND=sqlite
# EQUIPMENT_BACKEND=sqlite
# QMS_BACKEND=sqlite

# ── Tuning — all optional, sane defaults shown ────────────────────────────────
# PAGE_TIMEOUT_SECONDS=10
# EXTRACTION_WORKERS=2
# GC_INTERVAL_PAGES=20
# PROGRESS_WRITE_EVERY_N_PAGES=5
# URS_GENERATION_BATCH_SIZE=2
# URS_GENERATION_SLOW_WARNING_SECONDS=20
# URS_GENERATION_MAX_RETRIES=2

# ── CLI-only — never read by the running web app, no HTTP route depends ─────
# on these. Only needed when running the scripts below directly.

# scripts/bootstrap_super_admin.py (one-time super-admin account creation)
# SUPER_ADMIN_EMAIL=
# SUPER_ADMIN_PASSWORD=
# SUPER_ADMIN_DISPLAY_NAME=Super Admin

# scripts/check_*_parity.py, scripts/backfill_*.py (Phase 3 migration tooling)
# SUPABASE_SERVICE_ROLE_KEY=
